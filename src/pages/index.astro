---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Arash Bakhtiari';
const description =
  'Member of Technical Staff at Microsoft AI working on high-performance systems for large-scale AI.';

const links = [
  { label: 'Email', href: 'mailto:arash@bakhtiari.org' },
  { label: 'GitHub', href: 'https://github.com/arashb' },
  { label: 'LinkedIn', href: 'https://www.linkedin.com/in/arashbakhtiari' },
  { label: 'Google Scholar', href: 'https://scholar.google.com/citations?user=uVhQQx4AAAAJ&hl=en' },
];

const roles = [
  {
    company: 'Microsoft AI',
    companyUrl: 'https://microsoft.ai/',
    summaryHtml:
      'Contributing to inference and training software stacks, including Triton kernel optimizations, FP8 KV cache integration, and checkpointing and fault-tolerance infrastructure for large-scale training.',
  },
  {
    company: 'Microsoft DeepSpeed',
    companyUrl: 'https://www.deepspeed.ai/',
    summaryHtml:
      'Optimized <a href="https://openai.com/index/dall-e-3/">OpenAI DALL.E</a> inference latency and added <a href="https://www.deepspeed.ai/">DeepSpeed</a> Inference support for large language models including OPT, Falcon, and Phi-2.',
  },
  {
    company: 'Blaize',
    companyUrl: 'https://www.blaize.com/',
    summaryHtml:
      'Optimized computer vision deep learning models such as ResNet, OpenPose, and Mask R-CNN for the <a href="https://www.blaize.com/">Blaize</a> Graph Streaming Processor architecture.',
  },
  {
    company: 'Plumerai',
    companyUrl: 'https://plumerai.com/',
    summaryHtml:
      'Led technical design and development of Larq Compute Engine, an optimized inference engine for binarized neural networks on mobile and embedded devices.',
  },
  {
    company: 'Intel',
    companyUrl: 'https://www.intel.com/',
    summaryHtml:
      'Benchmarked Intel Deep Learning Boost instructions and implemented Control-Flow Enforcement Technology support in the GNU Debugger.',
  },
];
---

<BaseLayout title={title} description={description}>
  <main class="page-shell">
    <nav class="topbar" aria-label="Primary">
      <a class="brand" href="/" aria-label="Arash Bakhtiari home">AB</a>
      <div class="nav-links">
        <a href="https://scholar.google.com/citations?user=uVhQQx4AAAAJ&hl=en">Publications</a>
      </div>
    </nav>

    <section class="hero" aria-labelledby="intro-title">
      <aside class="profile-panel" aria-label="Profile">
        <img src="/assets/headshot.png" alt="Arash Bakhtiari" width="1130" height="1392" />
        <div>
          <p class="eyebrow">Redmond, WA</p>
          <h1 id="intro-title">Arash Bakhtiari</h1>
          <p class="role">Member of Technical Staff, Microsoft AI</p>
        </div>
        <div class="contact-grid" aria-label="Contact links">
          {links.map((link) => <a href={link.href}>{link.label}</a>)}
        </div>
      </aside>

      <article class="intro-copy">
        <p class="section-kicker">AI systems + high performance computing</p>
        <h2>Building high-performance systems for modern AI.</h2>
        <p>
          I am a Member of Technical Staff at
          <a href="https://microsoft.ai/">Microsoft AI</a>, where I work across
          inference and training software stacks for large-scale AI systems. My recent work includes
          Triton kernel optimizations, FP8 KV cache integration, and checkpointing and
          fault-tolerance infrastructure for distributed training.
        </p>
        <p>
          Before joining Microsoft AI, I worked on
          <a href="https://www.deepspeed.ai/">DeepSpeed</a> inference optimization for
          <a href="https://openai.com/index/dall-e-3/">OpenAI DALL.E</a> and large language
          models, edge AI acceleration at <a href="https://www.blaize.com/">Blaize</a>, and Larq
          Compute Engine at <a href="https://plumerai.com/">Plumerai</a>. My work sits at the
          intersection of high performance computing, machine learning systems, and architecture-aware
          optimization.
        </p>
      </article>
    </section>

    <section class="content-grid" aria-label="Professional background and education">
      <article class="section-block">
        <p class="section-kicker">Experience</p>
        <div class="timeline">
          {
            roles.map((role) => (
              <section>
                <h3>
                  <a href={role.companyUrl}>{role.company}</a>
                </h3>
                <p set:html={role.summaryHtml} />
              </section>
            ))
          }
        </div>
      </article>

      <article class="section-block">
        <p class="section-kicker">Research</p>
        <h2>Parallel algorithms, architecture-aware ML, and efficient inference.</h2>
        <p>
          I received my PhD in HPC and parallel algorithms from the
          <a href="https://www.ias.tum.de/">Institute for Advanced Study</a> at Technical University of
          Munich, under the supervision of
          <a href="https://www.oden.utexas.edu/people/1056">George Biros</a> and
          <a href="https://www.professoren.tum.de/en/bungartz-hans-joachim">
            Hans-Joachim Bungartz</a
          >.
        </p>
        <p>
          A full list of peer-reviewed and pre-print manuscripts is available on my
          <a href="https://scholar.google.com/citations?user=uVhQQx4AAAAJ&hl=en">
            Google Scholar profile</a
          >.
        </p>
      </article>
    </section>
  </main>
</BaseLayout>
